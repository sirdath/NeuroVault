# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Sidecar binaries (built by PyInstaller, not committed)
src-tauri/binaries/*.exe

# Python server
server/__pycache__/
server/.venv/
server/*.egg-info/
server/dist/
server/build/
*.pyc

# Tauri release bundles (installers are built locally and uploaded to GH releases)
src-tauri/target/
src-tauri/WixTools/

# Demo-video build artifacts (Remotion renders, hundreds of MB)
demo-video/out/
demo-video/.remotion/

# Eval run logs (keep baselines under eval/baselines/, ignore ad-hoc run logs)
eval/*.log

# Python caches that slip in under subdirs
**/__pycache__/
**/*.pyc

# ONNX model cache — auto-downloaded by fastembed-rs on first run
.fastembed_cache/
