{
  "identifier": "default",
  "description": "Capabilities for the main application and Settings windows",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "shell:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "updater:default",
    "process:allow-restart"
  ]
}
