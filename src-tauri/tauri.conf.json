{
  "$schema": "https://raw.githubusercontent.com/nicklascodes/tauri-docs/refs/heads/main/src/content/docs/_schema/config.schema.json",
  "productName": "NeuroVault",
  "version": "0.5.2",
  "identifier": "com.neurovault.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/stage-sidecar.mjs",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "NeuroVault",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "theme": "Dark"
      },
      {
        "label": "minitab",
        "url": "index.html?view=minitab",
        "title": "NeuroVault",
        "width": 248,
        "height": 132,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src ipc: http://ipc.localhost http://127.0.0.1:8765 https://api.github.com; font-src 'self' data:; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-src 'none'; form-action 'none'",
      "devCsp": "default-src 'self' customprotocol: asset: data: blob: 'unsafe-inline' 'unsafe-eval'; connect-src ipc: http://ipc.localhost http: https: ws: wss:; font-src 'self' data:; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; worker-src 'self' blob:"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "neurovault"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBNjRGMTFCMkY4NTVCQkIKUldTN1c0VXZHL0ZrU29aVzZXR2JyUjcwc2cwVUd4bHZxMnVNSEtGOU83dis4Y1FwSG44Ky92ekcK",
      "endpoints": [
        "https://github.com/sirdath/NeuroVault/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/neurovault-server"
    ],
    "resources": [
      "resources/vec0.*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 175,
          "y": 205
        },
        "applicationFolderPosition": {
          "x": 485,
          "y": 205
        }
      }
    }
  }
}
